# SQLite database file path for local/dev or single-instance pilots
GROCERY_DB_PATH=data/grocery_optimizer.db

# Production database URL. Use managed PostgreSQL for production.
# Example: postgresql://user:password@host:5432/grocery_optimizer
GROCERY_DATABASE_URL=

# Set only for a temporary single-instance production pilot that intentionally uses SQLite.
GROCERY_ALLOW_SQLITE_IN_PRODUCTION=false

# Local SQLite backup directory used by /maintenance/backup-database.
GROCERY_BACKUP_DIR=data/backups

# Set true after managed PostgreSQL point-in-time backups are enabled.
GROCERY_MANAGED_BACKUPS_ENABLED=false

# Comma-separated CORS origins for API
GROCERY_API_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Auth token TTL in minutes (default: 10080 = 7 days)
GROCERY_TOKEN_TTL_MINUTES=10080

# API semantic version string
GROCERY_API_VERSION=0.3.0-beta

# Environment name. Admin maintenance endpoints are open only in local/dev/test
# unless GROCERY_ADMIN_TOKEN is configured.
GROCERY_ENV=development

# Public HTTPS URL for production readiness checks.
GROCERY_PUBLIC_BASE_URL=

# Admin bearer token for maintenance and scheduler endpoints in production.
GROCERY_ADMIN_TOKEN=

# Lightweight in-memory API rate limiting for auth and expensive endpoints.
GROCERY_RATE_LIMIT_ENABLED=true

# Optional future partner credentials. The default verified public-flyer snapshot
# and /deals flow work without any of these keys. Leave blank unless a licensed
# provider supplies credentials and its disabled template is intentionally enabled.
LIVE_PRICING_FLIPP_KEY=

LIVE_PRICING_RETAILER_CATALOG_KEY=
LIVE_PRICING_LOBLAW_KEY=
LIVE_PRICING_METRO_KEY=
LIVE_PRICING_IGA_KEY=
LIVE_PRICING_FLYER_OCR_KEY=

# Route economics tuning.
GROCERY_ROUTE_COST_PER_KM=0.70
GROCERY_ROUTE_MIN_NET_SAVINGS=1.50
