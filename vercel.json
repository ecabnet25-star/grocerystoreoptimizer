{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python scripts/prepare_vercel_public.py",
  "outputDirectory": "public",
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
